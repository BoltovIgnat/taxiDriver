# === Публичные (клиент + сервер) ===
# Обязательно с https:// — иначе metadata и админка могут работать некорректно
NEXT_PUBLIC_SITE_URL=https://taxi-driver-ten.vercel.app
NEXT_PUBLIC_SITE_NAME=Таксопарк Партнёр
NEXT_PUBLIC_SITE_DESCRIPTION=Подключение водителей такси в городах России
NEXT_PUBLIC_CONTACT_PHONE=+78001234567
NEXT_PUBLIC_PHONE_DISPLAY=8 (800) 123-45-67
NEXT_PUBLIC_WHATSAPP_NUMBER=79001234567
NEXT_PUBLIC_TELEGRAM_USERNAME=taxi_partner
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# === Supabase (клиент + Postgres через Vercel Integration) ===
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Vercel + Supabase integration также создаёт (с опечаткой STORADGE):
# STORADGE_POSTGRES_URL=...              ← Payload использует автоматически
# STORADGE_POSTGRES_URL_NON_POOLING=...
# NEXT_PUBLIC_STORADGE_SUPABASE_URL=...
# NEXT_PUBLIC_STORADGE_SUPABASE_PUBLISHABLE_KEY=...

# === Payload CMS (только сервер) ===
PAYLOAD_SECRET=your-random-secret-at-least-32-characters-long

# Postgres — любой из вариантов ниже (достаточно одного pooled URL на Vercel):
# 1) Явно:
# DATABASE_URI=postgresql://...
# Supabase → Connect → ORMs → Transaction pooler (порт 6543, host *pooler.supabase.com*)
# Скопируйте в STORADGE_POSTGRES_URL или DATABASE_URI:
# DATABASE_URI=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# НЕ используйте direct db.[ref].supabase.co:5432 на Vercel — IPv6, таймауты!
# 3) Neon:
# DATABASE_URI=postgresql://...@ep-example-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URI=
# Локально без Postgres можно использовать SQLite:
# DATABASE_URI=file:./payload.db
PAYLOAD_ADMIN_EMAIL=admin@example.com
PAYLOAD_ADMIN_PASSWORD=your-secure-password
# Optional SMTP for password-reset emails (otherwise logged to console only)
# EMAIL_FROM=noreply@your-domain.ru
# EMAIL_FROM_NAME=Таксопарк
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# telegram | amocrm | bitrix24
CRM_PROVIDER=telegram
AMOCRM_SUBDOMAIN=
AMOCRM_ACCESS_TOKEN=
BITRIX24_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Legacy aliases (optional)
CONTACT_PHONE=+78001234567
WHATSAPP_NUMBER=79001234567
TELEGRAM_USERNAME=taxi_partner
