# === Публичные (клиент + сервер) ===
# Обязательно с https:// — иначе metadata и админка могут работать некорректно
NEXT_PUBLIC_SITE_URL=https://taxi-driver-ten.vercel.app
NEXT_PUBLIC_SITE_NAME=Таксопарк Партнёр
NEXT_PUBLIC_SITE_DESCRIPTION=Подключение водителей такси в городах России
NEXT_PUBLIC_CONTACT_PHONE=+78001234567
NEXT_PUBLIC_PHONE_DISPLAY=8 (800) 123-45-67
NEXT_PUBLIC_WHATSAPP_NUMBER=79001234567
NEXT_PUBLIC_TELEGRAM_USERNAME=taxi_partner
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# === Payload CMS (только сервер) ===
PAYLOAD_SECRET=your-random-secret-at-least-32-characters-long
# Postgres (Neon / Supabase / Vercel Postgres)
# Runtime (Vercel): pooled URL с -pooler в хосте
DATABASE_URI=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/db?sslmode=require
# Migrations/seed (локально): direct URL без -pooler (Neon → Connection → Direct)
# На Vercel не нужен — миграции не запускаются при сборке
DATABASE_URI_UNPOOLED=postgresql://user:password@ep-example.region.aws.neon.tech/db?sslmode=require
# Локально без Postgres можно использовать SQLite:
# DATABASE_URI=file:./payload.db
PAYLOAD_ADMIN_EMAIL=admin@example.com
PAYLOAD_ADMIN_PASSWORD=your-secure-password
# Optional SMTP for password-reset emails (otherwise logged to console only)
# EMAIL_FROM=noreply@your-domain.ru
# EMAIL_FROM_NAME=Таксопарк
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# telegram | amocrm | bitrix24
CRM_PROVIDER=telegram
AMOCRM_SUBDOMAIN=
AMOCRM_ACCESS_TOKEN=
BITRIX24_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Legacy aliases (optional)
CONTACT_PHONE=+78001234567
WHATSAPP_NUMBER=79001234567
TELEGRAM_USERNAME=taxi_partner
